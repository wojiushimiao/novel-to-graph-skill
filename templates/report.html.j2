<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<script src="https://cdn.jsdelivr.net/npm/cytoscape@3.28.1/dist/cytoscape.min.js"></script>
<style>
:root {
  --bg: #f5f7fa;
  --fg: #1f2937;
  --muted: #6b7280;
  --accent: #5B8FF9;
  --accent-soft: rgba(91, 143, 249, 0.12);
  --border: #e5e7eb;
  --card: #ffffff;
  --strong: #E86452;
  --weak: #9CA3AF;
}
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; height: 100%; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  background: var(--bg);
  color: var(--fg);
  font-size: 14px;
  line-height: 1.5;
}
header {
  background: var(--card);
  border-bottom: 1px solid var(--border);
  padding: 14px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
}
header h1 { margin: 0; font-size: 18px; font-weight: 600; }
header .meta { color: var(--muted); font-size: 12px; }
.stats-bar {
  display: flex;
  gap: 16px;
  padding: 10px 24px;
  background: var(--card);
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
  font-size: 13px;
}
.stat-item { color: var(--muted); }
.stat-item strong { color: var(--fg); font-weight: 600; margin-left: 4px; }
.layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 1px;
  background: var(--border);
  height: calc(100vh - 110px);
}
.panel {
  background: var(--card);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.panel-header {
  padding: 10px 14px;
  border-bottom: 1px solid var(--border);
  font-weight: 600;
  font-size: 13px;
  background: #fafbfc;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
#cy {
  flex: 1;
  background: #fafbfc;
  position: relative;
}
#cy canvas { left: 0 !important; }
.toolbar {
  display: flex;
  gap: 8px;
  padding: 10px 14px;
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
  align-items: center;
}
.toolbar input[type="text"] {
  flex: 1;
  min-width: 120px;
  padding: 6px 10px;
  border: 1px solid var(--border);
  border-radius: 4px;
  font-size: 13px;
  outline: none;
}
.toolbar input[type="text"]:focus { border-color: var(--accent); }
.toolbar select, .toolbar button {
  padding: 6px 10px;
  border: 1px solid var(--border);
  border-radius: 4px;
  background: var(--card);
  font-size: 13px;
  cursor: pointer;
}
.toolbar button:hover { background: var(--accent-soft); border-color: var(--accent); }
.toolbar label { font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 4px; cursor: pointer; }
.right-panel { display: flex; flex-direction: column; }
.tabs {
  display: flex;
  border-bottom: 1px solid var(--border);
  background: #fafbfc;
}
.tab {
  padding: 10px 14px;
  cursor: pointer;
  font-size: 13px;
  color: var(--muted);
  border-bottom: 2px solid transparent;
  flex: 1;
  text-align: center;
}
.tab.active { color: var(--accent); border-bottom-color: var(--accent); font-weight: 600; }
.tab-content { flex: 1; overflow-y: auto; padding: 0; }
.entity-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.entity-table th, .entity-table td { padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border); }
.entity-table th { background: #fafbfc; font-weight: 600; color: var(--muted); position: sticky; top: 0; z-index: 1; }
.entity-table tr { cursor: pointer; }
.entity-table tr:hover { background: var(--accent-soft); }
.entity-table tr.selected { background: var(--accent-soft); }
.type-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 500;
}
.type-character { background: #E8F5FE; color: #1E6FBA; }
.type-location { background: #E6F7E6; color: #2E7D32; }
.type-event { background: #FFF4E6; color: #B45309; }
.type-item { background: #F3E8FF; color: #7C3AED; }
.type-rule { background: #FEE2E2; color: #B91C1C; }
.type-system { background: #E0E7FF; color: #4338CA; }
.detail-panel { padding: 14px; }
.detail-panel h3 { margin: 0 0 8px 0; font-size: 15px; }
.detail-panel h4 { margin: 12px 0 6px 0; font-size: 13px; color: var(--muted); font-weight: 600; }
.detail-panel .field { margin-bottom: 8px; }
.detail-panel .field-label { color: var(--muted); font-size: 12px; }
.detail-panel .field-value { font-size: 13px; }
.detail-panel .relations-list { list-style: none; padding: 0; margin: 0; }
.detail-panel .relations-list li {
  padding: 6px 10px;
  background: #fafbfc;
  border: 1px solid var(--border);
  border-radius: 4px;
  margin-bottom: 4px;
  font-size: 12px;
}
.community-tag {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 12px;
  margin: 2px;
  cursor: pointer;
  border: 1px solid var(--border);
  background: var(--card);
}
.community-tag:hover { background: var(--accent-soft); }
.community-tag.active { background: var(--accent); color: white; border-color: var(--accent); }
.empty-state { padding: 40px 20px; text-align: center; color: var(--muted); font-size: 13px; }
</style>
</head>
<body>
<header>
  <div>
    <h1>{{ title }}</h1>
    <div class="meta">生成于 {{ generated_at[:19] | replace('T', ' ') }}</div>
  </div>
  <div>
    <button id="btn-export-md" type="button">导出 Markdown</button>
    <button id="btn-export-json" type="button">导出 JSON</button>
  </div>
</header>

<div class="stats-bar" id="stats-bar"></div>

<div class="layout">
  <div class="panel">
    <div class="toolbar">
      <input type="text" id="search-input" placeholder="搜索实体名称..." />
      <select id="filter-relation">
        <option value="">所有关系</option>
      </select>
      <label><input type="checkbox" id="filter-strong" checked /> 强</label>
      <label><input type="checkbox" id="filter-weak" checked /> 弱</label>
      <button id="btn-reset" type="button">重置</button>
    </div>
    <div id="cy"></div>
  </div>

  <div class="panel right-panel">
    <div class="tabs">
      <div class="tab active" data-tab="entities">实体列表</div>
      <div class="tab" data-tab="communities">社群</div>
      <div class="tab" data-tab="detail">详情</div>
    </div>
    <div class="tab-content" id="tab-content"></div>
  </div>
</div>

<script>window.NOVEL_DATA = {{ novel_data_json | safe }};</script>
<script>{{ static_js | safe }}</script>
</body>
</html>
